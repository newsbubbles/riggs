# Copy to .env and fill in. .env is gitignored — never commit real keys.

# RunPod API key (https://www.runpod.io/console/user/settings) — for cloud rigging.
RUNPOD_API_KEY=rpa_xxxxxxxxxxxxxxxxxxxx

# Hugging Face token (https://huggingface.co/settings/tokens), read scope.
# Required for the MIA engine: it loads the gated Mixamo bone templates.
# Also accept terms once at https://huggingface.co/datasets/jasongzy/Mixamo
HF_ACCESS_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
